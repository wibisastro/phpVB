{
    "name": "cyber-gov-labs/php-vb",
    "description": "Simple web framework built with PHP Vue and Bulma",
    "type": "project",
    "authors": [
        {
            "name": "Wibisono Sastrodiwiryo",
            "email": "wibi@alumni.ui.ac.id"
        }
    ],
    "require": {
        "php": "^8.4",
        "nikic/fast-route": "^1.3",
        "guzzlehttp/guzzle": "^7.8",
        "sergeytsalkov/meekrodb": "^2.5",
        "league/oauth2-client": "^2.7",
        "mailgun/mailgun-php": "^4.0",
        "twig/twig": "^3.20",
        "firebase/php-jwt": "^6.11",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "squizlabs/php_codesniffer": "^3.9",
        "phpcompatibility/php-compatibility": "^9.3",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Gov2lib\\": "core/lib",
            "App\\": "apps"
        },
        "files": [
            "core/lib/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpstan analyse core/lib apps --level=5",
        "cs-fix": "php-cs-fixer fix core/lib apps",
        "check": [
            "@lint",
            "@test"
        ]
    },
    "config": {
        "platform": {
            "php": "8.4"
        },
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
